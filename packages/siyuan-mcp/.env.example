# SiYuan MCP server configuration
# Default points at the deployed Cloud Run instance
SIYUAN_URL=https://siyuan.rickydata.org

# Token resolution priority (first set wins):
#   1. SIYUAN_KFDB_TOKEN — raw KFDB API key, used directly as ?kfdb_token=<value>
#   2. SIYUAN_KFDB_JWT — KnowledgeFlow Google-OAuth JWT, exchanged once via
#      POST /api/auth/kfdb/token. Derived key is held in memory only.
#   3. ~/.siyuan-mcp/credentials.json — paste-back token from `siyuan-mcp login`
#      (prefixed `siymcp_v1_<kfdb_api_key>`; the prefix is stripped before use).

# SIYUAN_KFDB_TOKEN=
# SIYUAN_KFDB_JWT=

# Transport: stdio (default) or http
# TRANSPORT=http
# PORT=8080
