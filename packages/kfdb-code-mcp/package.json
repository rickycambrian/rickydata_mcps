    "url": "git+https://github.com/rickycambrian/rickydata_mcps.git",
    "directory": "packages/kfdb-code-mcp"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kfdb-code-mcp": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
