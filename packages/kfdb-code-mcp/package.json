{
  "name": "@rickydata/kfdb-code-mcp",
  "version": "0.1.1",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Read-only KFDB code-intelligence MCP: semantic + full-text code search, symbol lookup, call-graph navigation, and agent context bundles. Supports a hardened bench mode that scopes every call to a single pinned repo corpus.",
  "repository": {
