# kfdb-code-mcp environment

# Base URL of the KFDB API. Defaults to production.
KFDB_API_URL=http://34.60.37.158

# Optional bearer token. Required only for tools that hit authenticated
# endpoints (get_callers / get_callees use /api/v1/graph/ego, which needs a
# valid tenant API key). Semantic + full-text search and context bundles are
# public and work without a key.
# KFDB_API_KEY=

# Bench mode. When set to a repo_id (UUID), the server registers ONLY the five
# scoped code-navigation tools and forces every upstream call to that single
# pinned-corpus scope with strict_scope=true. Used by rickydata_bench so an
# agent under evaluation can never reach other repos or HEAD-branch corpora.
# KFDB_BENCH_REPO_SCOPE=

# Max characters per tool response (snippets are additionally capped ~400 chars).
RESPONSE_MAX_LENGTH=200000

# Transport: stdio (default) or http
# TRANSPORT=stdio
# PORT=8080
