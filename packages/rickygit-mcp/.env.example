# rickygit-mcp environment

# Transport: stdio (default) or http
TRANSPORT=stdio
PORT=8080

# Path to the rickygit binary. If unset, the server resolves a sibling
# rickydata_git build, then falls back to `rickygit` on PATH.
# RICKYGIT_BIN=/path/to/rickydata_git/target/release/rickygit

# Default repository the tools operate on (defaults to the server cwd).
# RICKYGIT_REPO=/path/to/repo

# Shared relay for cross-fleet object distribution.
RICKYDATA_GIT_RELAY_URL=https://git.rickydata.org
