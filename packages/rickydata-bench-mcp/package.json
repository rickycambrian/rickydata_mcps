{
  "name": "@rickydata/rickydata-bench-mcp",
  "version": "0.2.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Read-only analysis + solution-engine MCP for the rickydata_bench agentic-coding benchmark: list runs, inspect run/trace summaries, leaderboards, config comparisons, task search, AND a deterministic pre-flight Solution Card (get_solution_recipe / browse_solution_patterns) over the public (gold-redacted) bench API. Never wired into bench runs.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rickycambrian/rickydata_mcps.git",
    "directory": "packages/rickydata-bench-mcp"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rickydata-bench-mcp": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
