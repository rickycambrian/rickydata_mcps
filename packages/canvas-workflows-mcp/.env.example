# canvas-workflows-mcp — drives rickydata_home canvas workflows over its
# authenticated /api/canvas/* routes. The wallet is the auth boundary.

# Base URL of rickydata_home.
HOME_API_URL=http://localhost:8788

# Operator wallet private key. Mints the scwt_ wallet token home requires.
# NEVER commit a real key. Absent => every tool fails closed (no anonymous fallback).
# CANVAS_MCP_PRIVATE_KEY=0x...

# Transport: stdio by default; set TRANSPORT=http or PORT for HTTP/SSE.
# TRANSPORT=http
# PORT=8080

# Optional: cap tool response text (chars).
# RESPONSE_MAX_LENGTH=120000
