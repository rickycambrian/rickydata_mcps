# notebooklm-mcp environment

# ── Auth (per-wallet Google session) ────────────────────────────────────────
# The Google session cookies, as the JSON produced by `npm run connect`. In a
# deployed container the gateway injects this from the per-wallet vault secret
# (sharing policy `isolated`, AES-256-GCM). Locally it falls back to state.json.
# Value is the Playwright storageState JSON (or a {"cookies":[...]} object).
# NOTEBOOKLM_COOKIES=

# Explicit path to a Playwright storageState file (local dev). When unset the
# server looks at $NOTEBOOKLM_STATE_PATH, then the platform default written by
# `npm run connect`.
# NOTEBOOKLM_STATE_PATH=

# ── batchexecute contract ───────────────────────────────────────────────────
# NotebookLM RPC host + app path. Defaults are correct for production NotebookLM.
# NOTEBOOKLM_ORIGIN=https://notebooklm.google.com
# NOTEBOOKLM_APP=LabsTailwindUi

# Pinned build label (`bl`) captured alongside the rpcids. Surfaced in /health so
# contract drift is visible. bootstrapTokens() refreshes the live value at runtime.
# NOTEBOOKLM_BL=

# ── Limits ──────────────────────────────────────────────────────────────────
# Hard ceiling on RPC-driven generations per process per day (account-flag guard).
NOTEBOOKLM_DAILY_LIMIT=50

# Max base64-inlined download size (bytes) before download_audio returns the
# signed URL only instead of the audio bytes. Default 20 MB.
NOTEBOOKLM_MAX_INLINE_BYTES=20971520

# Whole-response character cap.
RESPONSE_MAX_LENGTH=200000

# ── Gateway vault (used by `npm run connect` when deploying a wallet session) ──
# GATEWAY_URL=https://mcp.rickydata.org
# GATEWAY_TOKEN=

# Transport: stdio (default) or http
# TRANSPORT=stdio
# PORT=8080
