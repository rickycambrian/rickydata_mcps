{
  "name": "@rickydata/notebooklm-mcp",
  "version": "0.1.1",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Robust, deployable NotebookLM MCP driven by NotebookLM's internal batchexecute RPC API (no DOM scraping at runtime): create notebooks, add sources, generate + download Audio Overviews. Per-wallet Google session stored encrypted in the gateway vault. Browser is needed only for the one-time login (connect helper).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rickycambrian/rickydata_mcps.git",
    "directory": "packages/notebooklm-mcp"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "notebooklm-mcp": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "connect": "tsx src/dev/connect.ts",
    "capture": "tsx src/dev/capture.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "playwright": "^1.49.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
