# Private Product Copilot MCP feed source. No public/embedded fallback exists.
# Use a private endpoint that verifies the active wallet + derive session, or a
# local private snapshot during operator development.
PRODUCT_COPILOT_KFDB_API_URL=
PRODUCT_COPILOT_KFDB_API_KEY=
PRODUCT_COPILOT_PM_REPORT_PATH=/root/projects/rickycambrian/rickydata_sales_coach/docs/pm/reports/human-in-loop-roadmap-feed.json
# PRODUCT_COPILOT_PM_REPORT_URL=https://<private-product-copilot-domain>/api/roadmap/hil-feed

# Active wallet-derived private tenant material. These should be supplied by
# RickyData Gateway / the operator shell from the same wallet used by rickydata_notes.
# Never commit real values.
PRODUCT_COPILOT_WALLET_ADDRESS=
PRODUCT_COPILOT_KFDB_DERIVE_SESSION_ID=
PRODUCT_COPILOT_KFDB_DERIVE_KEY=

# Optional private endpoint bearer. The bearer alone is not a privacy boundary.
PRODUCT_COPILOT_PM_REPORT_BEARER_TOKEN=

# Transport: stdio by default; set TRANSPORT=http or PORT for Streamable HTTP.
# TRANSPORT=http
# PORT=8080
