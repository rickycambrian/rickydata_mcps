# Private Product Copilot MCP feed source. No public/embedded fallback exists.
# Production should receive wallet context from RickyData Gateway, not user-stored
# Product Copilot secrets.

# Optional operator/runtime endpoints. These are deployment config, not user secrets.
RICKYDATA_KFDB_URL=
# PRODUCT_COPILOT_PM_REPORT_URL=https://<private-product-copilot-domain>/api/roadmap/hil-feed
# PRODUCT_COPILOT_PM_REPORT_PATH=/root/projects/rickycambrian/rickydata_sales_coach/docs/pm/reports/human-in-loop-roadmap-feed.json

# Platform wallet context. In production this is injected by RickyData Gateway
# from the authenticated wallet/session. Local development may set a fake wallet
# only for dry-run tests; never commit real tokens or private values.
RICKYDATA_AUTH_WALLET_ADDRESS=
# RICKYDATA_AUTH_TOKEN=

# Transport: stdio by default; set TRANSPORT=http or PORT for Streamable HTTP.
# TRANSPORT=http
# PORT=3030
